generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                Role                 @default(USER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  posts               Post[]
  accounts            Account[]
  transactionCategories TransactionCategory[]
  transactions        Transaction[]
  budgets             Budget[]
}

// JWTではなくDBで管理するセッション方式。
// 理由: 「デバイス管理」「強制ログアウト」「ログイン履歴」など仕様書にある機能を、
// 後からこのテーブルを見るだけで実現できる（JWTは発行後に取り消せないため不向き）。
model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId])
}

// パスワードリセット用の使い捨てトークン。Sessionと同じ「トークンのハッシュだけ保存」方式。
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  body        String // Markdown本文
  excerpt     String?
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags        PostTag[]

  @@index([status, publishedAt])
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  posts PostTag[]
}

// PostとTagの中間テーブル。将来「タグ付けした日時」等を持たせたくなった時のため明示的に定義する
model PostTag {
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum AccountType {
  CASH
  BANK
  CREDIT_CARD
  E_MONEY
}

model Account {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         AccountType
  createdAt    DateTime      @default(now())
  transactions Transaction[]

  @@unique([userId, name])
}

// 家計簿のカテゴリ。ブログの Category とは別物なので名前を分けている
model TransactionCategory {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         TransactionType
  createdAt    DateTime        @default(now())
  transactions Transaction[]
  budget       Budget?

  @@unique([userId, name, type])
}

model Transaction {
  id         String               @id @default(cuid())
  userId     String
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       TransactionType
  amount     Int // 円単位の整数(小数のない通貨なので浮動小数点誤差を避けるためInt)
  date       DateTime
  memo       String?
  accountId  String
  account    Account              @relation(fields: [accountId], references: [id])
  categoryId String?
  category   TransactionCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([userId, date])
}

// カテゴリごとの月次予算(毎月繰り返し適用される想定。特定の月だけの予算は今回のスコープ外)
model Budget {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId    String              @unique
  category      TransactionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  monthlyAmount Int
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}
