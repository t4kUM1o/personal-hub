# PostgreSQL接続情報 (docker-compose.yml がこの値から自動でDATABASE_URLを組み立てます)
# 重要: パスワードは英数字のみにしてください。 # % @ / : などURLの特殊文字が入ると
#       接続文字列の解析に失敗します(記号を使いたい場合は `openssl rand -hex 24` を推奨)
POSTGRES_USER=personalhub
POSTGRES_PASSWORD=changeme
POSTGRES_DB=personalhub

# 初回セットアップ時にだけ使う、最初の管理者アカウント作成用の値
# 実行コマンド: docker compose run --rm migrate node prisma/seed.cjs
# 一度実行して管理者を作成したら、この2行はもう使わないので値を変えても消してもOK
SEED_ADMIN_EMAIL=you@example.com
SEED_ADMIN_PASSWORD=change-this-too

# ログインCookieにSecure属性を付けるかどうか。
# false: HTTP接続でも動作確認できる（今の「PoxmoxのVMに直接http://IP:3000でアクセス」の状態はこちら）
# true : リバースプロキシ経由でHTTPS化した後に切り替える（本番運用では必須）
COOKIE_SECURE=false
