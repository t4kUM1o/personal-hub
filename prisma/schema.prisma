generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                Role                 @default(USER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
}

// JWTではなくDBで管理するセッション方式。
// 理由: 「デバイス管理」「強制ログアウト」「ログイン履歴」など仕様書にある機能を、
// 後からこのテーブルを見るだけで実現できる（JWTは発行後に取り消せないため不向き）。
model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId])
}

// パスワードリセット用の使い捨てトークン。Sessionと同じ「トークンのハッシュだけ保存」方式。
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}
